# workers/model_fetch_worker.py
# Worker thread to fetch and test NVIDIA models, then generate descriptions for them.

from PySide6.QtCore import QThread, Signal
from openai import OpenAI

class ModelFetchWorker(QThread):
    progress = Signal(int, int, str, str)  # current, total, model_name, status
    finished = Signal(list)
    error = Signal(str)
    
    def __init__(self, api_key: str):
        super().__init__()
        self.api_key = api_key
        self.base_url = "https://integrate.api.nvidia.com/v1"
        self.working_count = 0
        
    def run(self):
        try:
            client = OpenAI(
                base_url=self.base_url,
                api_key=self.api_key,
                timeout=15.0
            )
            
            response = client.models.list()
            all_models = response.data
            total = len(all_models)
            
            working_models = []
            
            for i, model in enumerate(all_models):
                if self.isInterruptionRequested():
                    break
                
                model_id = model.id
                self.progress.emit(i + 1, total, model_id, "Testing...")
                
                try:
                    # Test if model works for chat
                    test_response = client.chat.completions.create(
                        model=model_id,
                        messages=[{"role": "user", "content": "Hi"}],
                        max_tokens=5,
                        timeout=5.0
                    )
                    
                    # Model works! Now ask it to describe itself
                    self.progress.emit(i + 1, total, model_id, "Generating description...")
                    
                    desc_response = client.chat.completions.create(
                        model=model_id,
                        messages=[
                            {"role": "system", "content": "You are a technical writer. Respond with ONLY one short sentence (15-30 words)."},
                            {"role": "user", "content": f"Describe yourself ({model_id}) in one sentence. What are you best at?"}
                        ],
                        max_tokens=60,
                        temperature=0.3,
                        timeout=10.0
                    )
                    
                    description = desc_response.choices[0].message.content.strip()
                    description = description.strip('"\'')
                    
                    working_models.append({
                        "id": model_id,
                        "name": self._format_name(model_id),
                        "description": description if description else "No description available",
                        "developer": model_id.split('/')[0] if '/' in model_id else "NVIDIA",
                        "free": True,
                    })
                    
                    self.working_count += 1
                    self.progress.emit(i + 1, total, model_id, f"✅ Working (found {self.working_count} so far)")
                    
                except Exception as e:
                    # Model doesn't work for chat - skip silently
                    self.progress.emit(i + 1, total, model_id, f"❌ Skipped (not chat-compatible)")
                    continue
                
                # Rate limit safety
                if i < total - 1:
                    self.msleep(200)  # 0.2 second between models
            
            self.finished.emit(working_models)
            
        except Exception as e:
            self.error.emit(str(e))
    
    def _format_name(self, model_id: str) -> str:
        if '/' in model_id:
            name = model_id.split('/')[-1]
        else:
            name = model_id
        name = name.replace('-', ' ').replace('_', ' ')
        words = name.split()
        return ' '.join(word.capitalize() for word in words)

